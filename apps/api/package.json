{
  "name": "@atiq/api",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --loader ts-node/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node lib/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf lib build dist"
  },
  "dependencies": {
    "@atiq/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "@prisma/client": "^6.4.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.85.4",
    "stripe": "^17.6.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "prisma": "^6.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
