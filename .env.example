# ==============================================================
# ATiQ Editor — Environment Variables
# Copy to .env in each app that needs it
# ==============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/atiq_dev"

# ── Server ────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-random-64-char-string"
JWT_EXPIRES_IN="7d"
MAGIC_LINK_EXPIRES_IN="15m"

# ── Email (magic link delivery) ───────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="ATiQ Editor <noreply@atiq.dev>"

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."

# ── LLM Providers ─────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
DEFAULT_MODEL="gpt-4o-mini"

# ── Web App ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8787"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
